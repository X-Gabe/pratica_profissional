<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cadastro de Administradores</title>
    <link rel="stylesheet" href="../css/styles.css">
</head>
<body>
    <div class="form-container">
        <h2>Cadastro de Novo Administrador</h2>
        <form id="cadastroAdminForm">
            <input type="text" id="nomeAdmin" placeholder="Nome completo" required>
            <input type="email" id="emailAdmin" placeholder="E-mail" required>
            <input type="password" id="senhaAdmin" placeholder="Senha" required>
            <button type="submit">Cadastrar Administrador</button>
        </form>
    </div>
    <script src="../js/scripts.js"></script>
</body>
</html>
